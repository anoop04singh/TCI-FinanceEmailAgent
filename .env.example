# n8n / local dry-run configuration
DRY_RUN=true
AS_OF_DATE=2026-05-10

# Gemini is configured as an n8n credential on the Google Gemini Chat Model node.
# Keep this only if you run a separate local/API experiment.
GEMINI_API_KEY=replace-with-your-gemini-key

# SMTP values are stored in n8n credentials for production.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=finance@example.com
SMTP_PASSWORD=replace-with-app-password
FINANCE_MANAGER_EMAIL=finance-manager@example.com
